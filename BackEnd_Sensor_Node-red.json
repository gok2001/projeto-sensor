    {
        "id": "0d8cd6320bad6167",
        "type": "function",
        "z": "7af0a913d5500150",
        "name": "insertLeitura",
        "func": "let now = new Date();\nlet temperatura = msg.payload.temperatura;\nlet umidade = msg.payload.umidade;\n\nconsole.log(now);\n\nlet datahora = now.toISOString().slice(0, 19).replace('T', ' ');;\n\n// protege contra SQL Injection com placeholders\nmsg.topic = \"insert into leitura (datahora, temperatura, umidade) values (?, ?, ?)\";\nmsg.payload = [datahora, temperatura, umidade];\n\nreturn msg;",
